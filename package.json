{
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@clack/prompts": "^1.2.0",
    "@microsoft/api-extractor": "^7.58.5",
    "@types/node": "^25.6.0",
    "@types/tmp": "^0.2.6",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "picocolors": "^1.1.1",
    "tmp": "^0.2.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "ultracite": "^7.6.0",
    "unplugin-dts": "^1.0.0",
    "vite": "^8.0.8",
    "vite-plugin-inspect": "^11.3.3",
    "vitest": "^4.1.4"
  },
  "name": "i18next-kit",
  "bin": {
    "i18next-kit": "dist/cli/index.js"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && chmod +x dist/cli/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "prepublishOnly": "npm run check && npm run typecheck && npm run test && npm run build",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "dev:run": "tsx scripts/dev-run.ts"
  },
  "type": "module",
  "version": "0.2.0",
  "description": "Type-safe i18next toolkit for Vite + React: scaffold,scan,and generate namespaces & types.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "i18next",
    "react",
    "vite",
    "vite-plugin",
    "i18n",
    "typescript",
    "codegen"
  ],
  "license": "MIT",
  "peerDependencies": {
    "i18next": "^23 || ^24 || ^25 || ^26",
    "i18next-resources-to-backend": "^1",
    "react-i18next": "^14 || ^15 || ^16 || ^17",
    "vite": "^5 || ^6 || ^7 || ^8"
  },
  "peerDependenciesMeta": {
    "react-i18next": {
      "optional": true
    },
    "i18next-resources-to-backend": {
      "optional": true
    }
  }
}
