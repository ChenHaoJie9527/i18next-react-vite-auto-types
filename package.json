{
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "typescript": "^6.0.3",
    "ultracite": "^7.6.0",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.4"
  },
  "name": "i18next-react-vite-auto-types",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "prepublishOnly": "npm run check && npm run typecheck && npm run test && npm run build",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "type": "module",
  "version": "0.0.1",
  "description": "A JS library scaffolded with Vite + TypeScript + Vitest.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "typescript",
    "vite",
    "vitest",
    "library"
  ],
  "license": "MIT",
  "dependencies": {
    "i18next": "^26.0.6",
    "react-i18next": "^17.0.4"
  }
}
